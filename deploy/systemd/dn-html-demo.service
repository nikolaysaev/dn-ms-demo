[Unit]
Description=CartAssist Test Demo Static Page
After=network.target

[Service]
Type=simple
User=devops
Group=devops
WorkingDirectory=/srv/apps/dn-html-demo
Environment=HOST=127.0.0.1
Environment=PORT=8090
ExecStart=/usr/bin/python3 /srv/apps/dn-html-demo/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
